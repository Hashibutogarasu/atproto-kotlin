{
  "lexicon": 1,
  "id": "example.uploadAvatar",
  "description": "Procedure with a pinned non-JSON input.encoding — exercises the raw-bytes service emission path with a default Content-Type.",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Upload a PNG avatar.",
      "input": {
        "encoding": "image/png"
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["blob"],
          "properties": {
            "blob": { "type": "blob" }
          }
        }
      }
    }
  }
}
