{
  "lexicon": 1,
  "id": "example.actor.defs",
  "description": ".defs flattening: multiple secondary defs in a .defs file. Package drops the .defs segment, class names use the bare fragment in PascalCase (no PrimaryName prefix).",
  "defs": {
    "profileView": {
      "type": "object",
      "required": ["did", "handle"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "handle": { "type": "string", "format": "handle" },
        "displayName": { "type": "string", "maxLength": 640 },
        "description": { "type": "string", "maxLength": 2560 }
      }
    },
    "profileViewBasic": {
      "type": "object",
      "required": ["did", "handle"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "handle": { "type": "string", "format": "handle" }
      }
    }
  }
}
